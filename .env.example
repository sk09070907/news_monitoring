# このファイルをコピーして .env を作成し、値を入力してください
# cp .env.example .env
# ※ .env は .gitignore に追加して絶対にコミットしないこと

# Google AI Studio API キー (AI要約に使用・無料枠あり)
# https://aistudio.google.com/apikey で取得
GOOGLE_API_KEY=your_google_api_key_here

# Discord Webhook URL
# Discord サーバー設定 → インテグレーション → ウェブフック で作成
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXXXXXXXXX/XXXXXXXXXX
